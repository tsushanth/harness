{
  "name": "@tsushanth/harness",
  "version": "0.1.0",
  "description": "Provider-agnostic tool use harness for open LLMs — schema-aware repair, type coercion, streaming, and eval suite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "example": "tsx src/example.ts",
    "eval": "tsx src/eval/run.ts",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "llm",
    "tool-use",
    "agents",
    "openai",
    "llama",
    "open-source-llm",
    "harness"
  ],
  "author": "tsushanth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsushanth/harness"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "openai": "^6.44.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
